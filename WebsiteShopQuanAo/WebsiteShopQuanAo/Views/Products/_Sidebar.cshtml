@model IEnumerable<WebsiteShopQuanAo.Models.NHOM_DANH_MUC>

@{
    string activeDm = ViewBag.MaDanhMuc as string;
    decimal? curMin  = ViewBag.Min;
    decimal? curMax  = ViewBag.Max;
    string curKw     = ViewBag.Keyword as string;
}

<style>
    /* Highlight danh mục đang chọn */
    .widget_categories a.cat-active {
        color: #6a7964 !important;
        font-weight: 600;
    }
    #apply-price-btn {
        background-color: #6a7964;
        color: #fff;
        border: none;
        padding: 6px 16px;
        border-radius: 3px;
        cursor: pointer;
    }
    #apply-price-btn:hover { background-color: #556059; }
    .reset-filter-link {
        display: inline-block;
        margin-left: 8px;
        font-size: 0.85em;
        color: #888;
    }
</style>

<!--sidebar widget start-->
<aside class="sidebar_widget">
    <div class="widget_inner">

        <div class="widget_list widget_categories">
            <h2>Categories</h2>
            <ul>
                @* Nút "Tất cả" – xóa bộ lọc danh mục nhưng GIỮ giá đang chọn *@
                <li>
                    <a href="@Url.Action("Index","Products", new { kw = curKw, min = curMin, max = curMax })"
                       class="@(string.IsNullOrEmpty(activeDm) ? "cat-active" : "")">
                        All Products
                    </a>
                </li>

                @foreach (var nhom in Model)
                {
                    <li class="widget_sub_categories">
                        <a href="javascript:void(0)" data-toggle="collapse" data-target="#nhom_@nhom.MANHOM">
                            @nhom.TENNHOM
                        </a>

                        <ul class="widget_dropdown_categories collapse show" id="nhom_@nhom.MANHOM">
                            @foreach (var dm in nhom.DANH_MUC.Where(x => x.TRANGTHAI == true))
                            {
                                bool isActive = (activeDm == dm.MADM);
                                @* Click danh mục → giữ nguyên kw + min + max, chỉ thay maDanhMuc *@
                                <li>
                                    <a href="@Url.Action("Index","Products", new { maDanhMuc = dm.MADM, kw = curKw, min = curMin, max = curMax })"
                                       class="@(isActive ? "cat-active" : "")">
                                        @dm.TENDM
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>
                }
            </ul>
        </div>

        <div class="widget_list widget_filter">
            <h2>Filter By Price</h2>

            @* Form Apply giá — GIỮ NGUYÊN maDanhMuc + kw đang chọn *@
            <form method="get" action="@Url.Action("Index","Products")">
                <input type="hidden" name="kw"         value="@curKw" />
                <input type="hidden" name="maDanhMuc"  value="@activeDm" />

                <!-- PRICE RANGE -->
                <div class="filter__list slider_range">
                    <h3>price</h3>

                    <div id="slider-range"></div>

                    <span>Range:</span>
                    <input type="text" id="amount" style="width:100%;" readonly />

                    <input type="hidden" name="min" id="minPrice" />
                    <input type="hidden" name="max" id="maxPrice" />

                    <div class="mt-3">
                        <button type="submit" id="apply-price-btn">Apply Filter</button>
                        @* Reset giá nhưng GIỮ danh mục đang chọn *@
                        <a href="@Url.Action("Index","Products", new { kw = curKw, maDanhMuc = activeDm })"
                           class="reset-filter-link">Reset price</a>
                    </div>
                </div>
            </form>
        </div>

    </div>
</aside>
<!--sidebar widget end-->
