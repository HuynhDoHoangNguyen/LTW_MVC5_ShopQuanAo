@model IEnumerable<WebsiteShopQuanAo.Models.ProductItemVM>

<style>
    /* Đồng bộ màu phân trang với theme chính (#6a7964) */
    .shop-pagination .page-item.active .page-link {
        background-color: #6a7964 !important;
        border-color: #6a7964 !important;
        color: #fff !important;
    }
    .shop-pagination .page-link {
        color: #272727;
    }
    .shop-pagination .page-link:hover {
        color: #6a7964;
        background-color: #f8f9fa;
        border-color: #ddd;
    }
</style>

@{
    ViewBag.Title = "Shop";
    Layout = "~/Views/Shared/_MainUserLayout.cshtml";

    string imgBase = Url.Content("~/UI_User/assets/img/product/small-product/");
    string noImg = Url.Content("~/Content/assets/img/no-image.png");

    int pageSize = 5;
    int totalItems = Model != null ? Model.Count() : 0;
    int totalPages = (int)Math.Ceiling((double)totalItems / pageSize);

    // Đọc page từ query string, mặc định = 1
    int currentPage = 1;
    int.TryParse(Request.QueryString["page"], out currentPage);
    if (currentPage < 1) { currentPage = 1; } 
    if (currentPage > totalPages && totalPages > 0) { currentPage = totalPages; }


    // Cắt danh sách theo trang
    var pagedProducts = Model != null
        ? Model.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList()
        : new List<WebsiteShopQuanAo.Models.ProductItemVM>();

    // Helper: build URL giữ nguyên tất cả query string, chỉ thay "page"
    Func<int, string> pageUrl = pg =>
    {
        var qs = HttpUtility.ParseQueryString(Request.QueryString.ToString());
        qs["page"] = pg.ToString();
        return Request.Url.AbsolutePath + "?" + qs.ToString();
    };
}

<div class="shop_section shop_reverse">
    <div class="container">
        <div class="row">

            <div class="col-lg-3 col-md-12">
                @Html.Action("Sidebar", "Products")
            </div>

            <div class="col-lg-9 col-md-12">

                <div class="breadcrumb_content">
                    <ul>
                        <li><a href="@Url.Action("Index","Home")">home</a></li>
                        <li>shop</li>
                    </ul>
                </div>

                <div class="shop_banner d-flex align-items-center"
                     data-bgimg="@Url.Content("~/UI_User/assets/img/bg/shop_bg.jpg")">
                    <div class="shop_banner_text">
                        <h2>essential <br /> wears</h2>
                        <p>The collections basic items <br /> essential for all girls</p>
                    </div>
                </div>

                @* ── Thông tin trang ── *@
                @if (totalItems > 0)
                {
                    int from = (currentPage - 1) * pageSize + 1;
                    int to = Math.Min(currentPage * pageSize, totalItems);
                    <p class="shop-page-info text-muted mb-2">
                        Hiển thị <strong>@from–@to</strong> / <strong>@totalItems</strong> sản phẩm
                    </p>
                }

                @* ── Lưới sản phẩm ── *@
                <div class="row shop_wrapper">
                    @if (!pagedProducts.Any())
                    {
                        <div class="col-12">
                            <div class="section_title text-center mb-130">
                                <h2>No products found</h2>
                            </div>
                        </div>
                    }
                    else
                    {
                        foreach (var sp in pagedProducts)
                        {
                            var imgUrl = string.IsNullOrWhiteSpace(sp.HinhAnh)
                                ? noImg
                                : (imgBase + sp.HinhAnh.Trim());

                            <div class="col-lg-4 col-md-4 col-sm-6">
                                <div class="single_product">
                                    <div class="product_thumb">
                                        <a href="@Url.Action("Details", "Products", new { id = sp.MaSanPham })">
                                            <img class="main-img"
                                                 src="@imgUrl"
                                                 alt="@sp.TenSanPham" />
                                        </a>
                                    </div>

                                    <figcaption class="product_content text-center">
                                        <h4 class="product_name">
                                            <a href="@Url.Action("Details","Products", new { id = sp.MaSanPham })">
                                                @sp.TenSanPham
                                            </a>
                                        </h4>

                                        <div class="price_box">
                                            <span class="current_price">
                                                @sp.GiaBan.ToString("N0") ₫
                                            </span>
                                        </div>

                                        <div class="add_to_cart">
                                            <a class="btn btn-primary"
                                               href="@Url.Action("Details","Products", new { id = sp.MaSanPham })">
                                                See more
                                            </a>
                                        </div>
                                    </figcaption>
                                </div>
                            </div>
                        }
                    }
                </div>

                @* ── Phân trang ── *@
                @if (totalPages > 1)
                {
                    <nav class="shop-pagination d-flex justify-content-center mt-4" aria-label="Phân trang sản phẩm">
                        <ul class="pagination">

                            @* Nút « Trước *@
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link"
                                   href="@(currentPage > 1 ? pageUrl(currentPage - 1) : "#")"
                                   aria-label="Trang trước">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>

                            @* Các nút số trang *@
                            @{
                                // Hiển thị tối đa 5 nút số, căn giữa trang hiện tại
                                int maxButtons = 5;
                                int startPage = Math.Max(1, currentPage - maxButtons / 2);
                                int endPage = Math.Min(totalPages, startPage + maxButtons - 1);
                                // Căn lại nếu gần cuối
                                if (endPage - startPage < maxButtons - 1)
                                {

                                    startPage = Math.Max(1, endPage - maxButtons + 1);
                                }

                            }

                            @if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@pageUrl(1)">1</a>
                                </li>
                                if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">…</span>
                                    </li>
                                }
                            }

                            @for (int p = startPage; p <= endPage; p++)
                            {
                                <li class="page-item @(p == currentPage ? "active" : "")">
                                    <a class="page-link" href="@pageUrl(p)">@p</a>
                                </li>
                            }

                            @if (endPage < totalPages)
                            {
                                if (endPage < totalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">…</span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a class="page-link" href="@pageUrl(totalPages)">@totalPages</a>
                                </li>
                            }

                            @* Nút Sau » *@
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link"
                                   href="@(currentPage < totalPages ? pageUrl(currentPage + 1) : "#")"
                                   aria-label="Trang sau">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>

                        </ul>
                    </nav>
                }

            </div>
        </div>
    </div>
</div>

@section scripts{
    <script>
        $(function () {
            // ── Slider lọc giá ──
            if (!$.ui || !$.ui.slider) return;

            var minDefault = 0;
            var maxDefault = 2000000;

            var url = new URL(window.location.href);
            var minQ = parseInt(url.searchParams.get("min")) || minDefault;
            var maxQ = parseInt(url.searchParams.get("max")) || maxDefault;

            $("#slider-range").slider({
                range: true,
                min: minDefault,
                max: maxDefault,
                step: 50000,
                values: [minQ, maxQ],
                slide: function (event, ui) {
                    $("#amount").val(
                        ui.values[0].toLocaleString("vi-VN") + " ₫ – " +
                        ui.values[1].toLocaleString("vi-VN") + " ₫"
                    );
                    $("#minPrice").val(ui.values[0]);
                    $("#maxPrice").val(ui.values[1]);
                }
            });

            var init = $("#slider-range").slider("values");
            $("#amount").val(
                init[0].toLocaleString("vi-VN") + " ₫ – " +
                init[1].toLocaleString("vi-VN") + " ₫"
            );
            $("#minPrice").val(init[0]);
            $("#maxPrice").val(init[1]);
        });
    </script>
}
